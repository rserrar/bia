{
  "version": "0.1.0",
  "resources": {
    "runs": {
      "create": {
        "method": "POST",
        "path": "/runs",
        "body": {
          "code_version": "string",
          "metadata": "object"
        },
        "response": {
          "run_id": "string",
          "status": "queued|running|retrying|completed|failed|cancelled",
          "created_at": "iso8601"
        }
      },
      "heartbeat": {
        "method": "POST",
        "path": "/runs/{run_id}/heartbeat",
        "response": {
          "run_id": "string",
          "status": "string",
          "heartbeat_at": "iso8601"
        }
      },
      "status": {
        "method": "POST",
        "path": "/runs/{run_id}/status",
        "body": {
          "status": "queued|running|retrying|completed|failed|cancelled",
          "generation": "integer|null"
        }
      },
      "get": {
        "method": "GET",
        "path": "/runs/{run_id}"
      },
      "summary": {
        "method": "GET",
        "path": "/runs/{run_id}/summary"
      }
    },
    "events": {
      "create": {
        "method": "POST",
        "path": "/runs/{run_id}/events",
        "body": {
          "event_type": "string",
          "label": "string",
          "details": "object"
        }
      }
    },
    "metrics": {
      "create": {
        "method": "POST",
        "path": "/runs/{run_id}/metrics",
        "body": {
          "model_id": "string",
          "generation": "integer",
          "metrics": "object"
        }
      }
    },
    "artifacts": {
      "create": {
        "method": "POST",
        "path": "/runs/{run_id}/artifacts",
        "body": {
          "artifact_type": "string",
          "uri": "string",
          "storage": "drive|server",
          "checksum": "string|null",
          "metadata": "object"
        }
      }
    },
    "maintenance": {
      "watchdog": {
        "method": "POST",
        "path": "/maintenance/watchdog",
        "body": {
          "stale_after_seconds": "integer"
        },
        "response": {
          "updated_count": "integer",
          "updated_runs": "string[]"
        }
      },
      "process_model_proposals_phase0": {
        "method": "POST",
        "path": "/maintenance/process-model-proposals-phase0",
        "body": {
          "limit": "integer"
        },
        "response": {
          "processed_count": "integer",
          "processed": "object[]"
        }
      }
    },
    "model_proposals": {
      "create": {
        "method": "POST",
        "path": "/model-proposals",
        "body": {
          "source_run_id": "string",
          "base_model_id": "string",
          "proposal": "object",
          "llm_metadata": "object"
        },
        "response": {
          "proposal_id": "string",
          "status": "draft|queued_phase0|validated_phase0|accepted|rejected",
          "created_at": "iso8601"
        }
      },
      "list": {
        "method": "GET",
        "path": "/model-proposals?limit=integer"
      },
      "get": {
        "method": "GET",
        "path": "/model-proposals/{proposal_id}"
      },
      "status": {
        "method": "POST",
        "path": "/model-proposals/{proposal_id}/status",
        "body": {
          "status": "draft|queued_phase0|validated_phase0|accepted|rejected"
        }
      },
      "enqueue_phase0": {
        "method": "POST",
        "path": "/model-proposals/{proposal_id}/enqueue-phase0"
      }
    }
  }
}
